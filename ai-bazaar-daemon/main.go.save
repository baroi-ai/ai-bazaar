package main

import (
	"bufio"
	"fmt"
	"log"
	"net/http"
	"os/exec"
	"path/filepath"

	"github.com/gorilla/websocket"
)

var upgrader = websocket.Upgrader{
	// Allow connections from your webapp (e.g., localhost:3000 or aibazaars.store)
	CheckOrigin: func(r *http.Request) bool { return true },
}

// Struct to handle incoming JSON commands from AI Bazaar UI
type AppRequest struct {
	Action string `json:"action"` // e.g., "RUN" or "BUILD"
	Image  string `json:"image"`  // e.g., "alpine" or an AI model image
}

func handleWebSocket(w http.ResponseWriter, r *http.Request) {
	conn, err := upgrader.Upgrade(w, r, nil)
	if err != nil {
		log.Println("Upgrade error:", err)
		return
	}
	defer conn.Close()
	fmt.Println("🚀 AI Bazaar WebApp connected to Local Daemon!")

	for {
		var req AppRequest
		err := conn.ReadJSON(&req)
		if err != nil {
			log.Println("Read error:", err)
			break
		}

		if req.Action == "RUN" {
			conn.WriteMessage(websocket.TextMessage, []byte("🔄 Spinning up container using local Podman..."))

			// Find our portable Podman binary
			podmanPath, _ := filepath.Abs("./bin/podman")

			// Execute Podman portable command: podman run --rm <image> echo "Hello from GPU/CPU Container"
			// In production, your Go code will dynamically insert GPU flags here like `--device /dev/dri`
			cmd := exec.Command(podmanPath, "run", "--rm", req.Image, "echo", "Hello from Local Container! Podman is successfully orchestrated.")

			// Stream container stdout logs back to the browser via WebSocket
			stdout, _ := cmd.StdoutPipe()
			cmd.Start()

			scanner := bufio.NewScanner(stdout)
			for scanner.Scan() {
				conn.WriteMessage(websocket.TextMessage, []byte("📦 [Container Log]: "+scanner.Text()))
			}

			cmd.Wait()
			conn.WriteMessage(websocket.TextMessage, []byte("✅ Task Completed. Podman cleaned up resources instantly!"))
		}
	}
}

func main() {
	http.HandleFunc("/ws", handleWebSocket)
	fmt.Println("📡 Local Bridge Daemon running on http://127.0.0.1:4500")
	log.Fatal(http.ListenAndServe(":4500", nil))
}


